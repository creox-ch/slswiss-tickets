# ── Payrexx ──────────────────────────────────────────────
PAYREXX_INSTANCE=slswiss
PAYREXX_API_SECRET=            # Payrexx → Settings → API → API Secret
PAYREXX_WEBHOOK_SIGNING_KEY=   # signing key вебхука (создаётся при добавлении вебхука)
# Без signing key вебхук ОТКЛОНЯЕТСЯ (fail-closed). Только на время настройки
# можно временно разрешить неподписанные вебхуки:
# ALLOW_UNSIGNED_WEBHOOKS=1

# ── Билет ────────────────────────────────────────────────
TICKET_PRICE_RAPPEN=100        # цена билета в раппенах (100 = 1.00 CHF); клиент цену НЕ присылает
CHECKIN_STAFF_KEY=             # ключ персонала для /api/checkin; пусто = чек-ин без ключа (только тест!)

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://dwcmiommviauwzkhkbki.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # Supabase → Settings → API → service_role (СЕКРЕТ, только сервер!)

# ── Resend ───────────────────────────────────────────────
RESEND_API_KEY=
TICKET_FROM_EMAIL=SoiLüDi <noreply@slswiss.ch>

# ── Прочее ───────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:3000   # в проде: https://tickets.slswiss.ch (или vercel-домен)

# ── DEV-ТЕСТ без Payrexx ─────────────────────────────────
# Пока нет Payrexx API: выпустить оплаченный билет вручную.
# Задай любую длинную случайную строку. Вызов: /api/dev/issue?key=ЭТА_СТРОКА&email=...
# Убери эту переменную (или удали app/api/dev) перед продом.
DEV_ISSUE_TOKEN=
